# LLM 的 API Key（OpenAI 兼容格式）。演化、可解性、难度三阶段均需使用。
# 复制本文件为 .env 并填入你的值：
#   cp .env.example .env
CODE2MATH_API_KEY=sk-your-api-key-here

# API 端点（OpenAI 兼容格式）。三阶段共用。
CODE2MATH_API_BASE=https://gateway.stem-align.com/v1

# 模型 ID，三阶段共用：doubao-seed-1-6-thinking-250715、doubao-seed-2-0-pro-260215、gemini-3-pro-preview
CODE2MATH_MODEL_ID=doubao-seed-2-0-pro-260215